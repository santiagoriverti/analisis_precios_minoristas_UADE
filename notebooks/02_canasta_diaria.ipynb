  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# 02 — Canasta ICM-UADE por provincia (datos diarios)\n",
    "\n",
    "Calcula el valor de la canasta de 30 productos por provincia usando un ZIP diario.\n",
    "\n",
    "**Input:** `data/input/diarios/AAAA-MM-DD.zip` + maestros  \n",
    "**Output:** `data/output/canasta_diaria_AAAA-MM-DD.xlsx` + coropleta PNG"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import sys\n",
    "from pathlib import Path\n",
    "\n",
    "IS_COLAB = 'google.colab' in str(get_ipython()) if get_ipython() else False\n",
    "PROJECT_ROOT = Path('/content/analisis_precios_minoristas_UADE') if IS_COLAB else Path('..').resolve()\n",
    "if str(PROJECT_ROOT / 'src') not in sys.path:\n",
    "    sys.path.insert(0, str(PROJECT_ROOT / 'src'))\n",
    "\n",
    "# ── CONFIGURACIÓN ──────────────────────────────────────────────────────────\n",
    "ZIP_DIARIO          = PROJECT_ROOT / 'data' / 'input' / 'diarios' / '2026-04-26.zip'\n",
    "MAESTRO_PRODUCTOS   = PROJECT_ROOT / 'data' / 'masters' / 'Maestro de Productos Interno.xlsx'\n",
    "MAESTRO_SUCURSALES  = PROJECT_ROOT / 'data' / 'masters' / 'maestro_sucursales_completo.xlsx'\n",
    "GEOJSON_PROVINCIAS  = PROJECT_ROOT / 'data' / 'masters' / 'ar.json'  # GeoJSON opcional\n",
    "\n",
    "print('Configuración lista')\n",
    "print(f'ZIP existe: {ZIP_DIARIO.exists()}')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import pandas as pd\n",
    "from collections import defaultdict\n",
    "\n",
    "from sepa.pipeline.loader import read_daily_zip, load_master_products, load_master_branches\n",
    "from sepa.pipeline.cleaner import normalize_ean_column\n",
    "from sepa.pipeline.enricher import filter_excluded_chains, enrich_with_branches\n",
    "from sepa.config.canasta import CANASTA_EANS, get_canasta_df\n",
    "from sepa.config.geo import normalize_provincia\n",
    "\n",
    "# Leer y filtrar a EANs de la canasta\n",
    "raw = read_daily_zip(ZIP_DIARIO)\n",
    "df = raw.get('productos', pd.DataFrame())\n",
    "df = normalize_ean_column(df, 'productos_ean')\n",
    "df = filter_excluded_chains(df)\n",
    "df = df[df['ean_norm'].isin(CANASTA_EANS)].copy()\n",
    "\n",
    "print(f'Filas de canasta: {len(df):,}')\n",
    "print(f'EANs encontrados: {df[\"ean_norm\"].nunique()} de 30')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Enriquecer con maestro de sucursales para obtener provincia\n",
    "if MAESTRO_SUCURSALES.exists():\n",
    "    mb = load_master_branches(MAESTRO_SUCURSALES)\n",
    "    df = enrich_with_branches(df, mb)\n",
    "    print('Provincias únicas encontradas:', df['provincia'].nunique() if 'provincia' in df.columns else 'N/A')\n",
    "else:\n",
    "    print('⚠ Sin maestro de sucursales — no se puede calcular por provincia')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Calcular precio promedio por (EAN, provincia)\n",
    "# Los datos diarios tienen columnas precio_YYYYMMDD → tomamos el primero disponible o promedio\n",
    "import numpy as np\n",
    "import re\n",
    "\n",
    "price_cols = [c for c in df.columns if re.match(r'productos_precio', c)]\n",
    "if not price_cols:\n",
    "    price_cols = [c for c in df.columns if 'precio' in c.lower() and c != 'ean_norm']\n",
    "\n",
    "df['precio_unitario'] = df[price_cols].apply(pd.to_numeric, errors='coerce').mean(axis=1)\n",
    "df = df[df['precio_unitario'] > 5].copy()\n",
    "\n",
    "group_cols = ['ean_norm'] + (['provincia'] if 'provincia' in df.columns else [])\n",
    "df_avg = df.groupby(group_cols)['precio_unitario'].mean().reset_index()\n",
    "\n",
    "print(f'Precios promedio calculados: {len(df_avg):,} combinaciones')\n",
    "df_avg.head()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Calcular canasta por provincia\n",
    "canasta_df = get_canasta_df()[['ean_str', 'nombre', 'categoria', 'cantidad']].rename(columns={'ean_str': 'ean_norm'})\n",
    "\n",
    "# Precio nacional de referencia para imputación\n",
    "national_price = df.groupby('ean_norm')['precio_unitario'].mean().to_dict()\n",
    "\n",
    "if 'provincia' in df_avg.columns:\n",
    "    provincias = df_avg['provincia'].unique()\n",
    "    rows = []\n",
    "    for prov in provincias:\n",
    "        df_p = df_avg[df_avg['provincia'] == prov].set_index('ean_norm')['precio_unitario'].to_dict()\n",
    "        total = 0\n",
    "        n_propios = 0\n",
    "        for _, prod in canasta_df.iterrows():\n",
    "            ean = prod['ean_norm']\n",
    "            qty = prod['cantidad']\n",
    "            if ean in df_p:\n",
    "                total += df_p[ean] * qty\n",
    "                n_propios += 1\n",
    "            elif ean in national_price:\n",
    "                total += national_price[ean] * qty\n",
    "        rows.append({'provincia': prov, 'canasta_total': total, 'n_productos_propios': n_propios})\n",
    "    \n",
    "    df_canasta = pd.DataFrame(rows).sort_values('canasta_total')\n",
    "    avg = df_canasta['canasta_total'].mean()\n",
    "    df_canasta['vs_promedio_pct'] = (df_canasta['canasta_total'] / avg - 1) * 100\n",
    "    df_canasta['ranking'] = range(1, len(df_canasta)+1)\n",
    "    \n",
    "    print(f'\\nCanasta por {len(df_canasta)} provincias | Promedio: ${avg:,.0f}')\n",
    "    display(df_canasta[['ranking','provincia','canasta_total','vs_promedio_pct','n_productos_propios']])\n",
    "else:\n",
    "    # Sin provincia: calcular a nivel nacional\n",
    "    total = sum(national_price.get(r['ean_norm'], 0) * r['cantidad'] for _, r in canasta_df.iterrows())\n",
    "    df_canasta = pd.DataFrame([{'provincia': 'Nacional', 'canasta_total': total}])\n",
    "    print(f'Canasta nacional: ${total:,.0f}')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Gráfico de ranking provincial\n",
    "from sepa.viz.charts import plot_province_ranking\n",
    "\n",
    "if 'provincia' in df_canasta.columns and len(df_canasta) > 1:\n",
    "    df_chart = df_canasta.copy()\n",
    "    df_chart['mes'] = ZIP_DIARIO.stem  # usar fecha como etiqueta\n",
    "    out_chart = PROJECT_ROOT / 'products' / f'ranking_provincias_{ZIP_DIARIO.stem}.png'\n",
    "    plot_province_ranking(df_chart.rename(columns={'canasta_total': 'canasta_provincia'}),\n",
    "                          out_chart, mes=ZIP_DIARIO.stem)\n",
    "    print(f'Gráfico guardado: {out_chart}')\n",
    "    from IPython.display import Image\n",
    "    display(Image(str(out_chart)))"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Exportar\n",
    "from sepa.viz.exports import save_excel\n",
    "\n",
    "out_excel = PROJECT_ROOT / 'data' / 'output' / f'canasta_diaria_{ZIP_DIARIO.stem}.xlsx'\n",
    "save_excel({'ranking_provincias': df_canasta, 'precios_canasta': df_avg, 'definicion': canasta_df}, out_excel)\n",
    "print(f'Excel guardado: {out_excel}')"
   ]
  }
 ],
