{
 "cells": [
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# 05 — Consolidación multi-semestral y comparativa IPC\n",
    "\n",
    "Consolida todos los semestres procesados, construye el índice base 100 (mayo 2023),\n",
    "lo compara contra el IPC INDEC y genera todos los gráficos de publicación.\n",
    "\n",
    "**Input:** `data/output/canasta_*_serie.xlsx` + `data/masters/IPC.xlsx`  \n",
    "**Output:** `data/output/canasta_SEPA_consolidado.xlsx` + PNGs en `products/`"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import sys\n",
    "from pathlib import Path\n",
    "\n",
    "IS_COLAB = 'google.colab' in str(get_ipython()) if get_ipython() else False\n",
    "PROJECT_ROOT = Path('/content/analisis_precios_minoristas_UADE') if IS_COLAB else Path('..').resolve()\n",
    "if str(PROJECT_ROOT / 'src') not in sys.path:\n",
    "    sys.path.insert(0, str(PROJECT_ROOT / 'src'))\n",
    "\n",
    "OUTPUT_DIR   = PROJECT_ROOT / 'data' / 'output'\n",
    "MASTERS_DIR  = PROJECT_ROOT / 'data' / 'masters'\n",
    "PRODUCTS_DIR = PROJECT_ROOT / 'products'\n",
    "IPC_PATH     = MASTERS_DIR / 'IPC.xlsx'\n",
    "FROM_MONTH   = '2023-05'  # período válido desde\n",
    "\n",
    "semester_files = sorted(OUTPUT_DIR.glob('canasta_*_serie.xlsx'))\n",
    "print(f'Archivos semestrales encontrados: {len(semester_files)}')\n",
    "for f in semester_files:\n",
    "    print(f'  {f.name}')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "from sepa.analysis.timeseries import consolidate_semesters, build_national_index, load_ipc, build_comparative\n",
    "\n",
    "# Consolidar\n",
    "series = consolidate_semesters(semester_files)\n",
    "df_nat   = series['nacional']\n",
    "df_prov  = series['provincia']\n",
    "df_reg   = series['region']\n",
    "\n",
    "print(f'Serie nacional: {len(df_nat)} meses ({df_nat[\"mes\"].min()} → {df_nat[\"mes\"].max()})')\n",
    "print(f'Serie provincial: {len(df_prov)} filas')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Filtrar desde el período válido\n",
    "df_nat_valid = df_nat[df_nat['mes'] >= FROM_MONTH].copy()\n",
    "\n",
    "# Índice base 100\n",
    "idx = build_national_index(df_nat_valid, base_month=FROM_MONTH,\n",
    "                           null_months=['2023-05', '2023-06'])  # variaciones no comparables\n",
    "\n",
    "print(f'Índice base 100 ({FROM_MONTH}):')\n",
    "print(f'  Primer mes: {idx[\"mes\"].iloc[0]} = {idx[\"indice\"].iloc[0]:.1f}')\n",
    "print(f'  Último mes: {idx[\"mes\"].iloc[-1]} = {idx[\"indice\"].iloc[-1]:.1f}')\n",
    "val_col = [c for c in idx.columns if 'canasta' in c or 'valor' in c][0]\n",
    "print(f'  Acumulado: +{(idx[val_col].iloc[-1]/idx[val_col].iloc[0]-1)*100:.1f}%')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Cargar IPC y construir comparativa\n",
    "import pandas as pd\n",
    "\n",
    "if IPC_PATH.exists():\n",
    "    df_ipc = load_ipc(IPC_PATH)\n",
    "    df_comp = build_comparative(df_nat_valid, df_ipc, base_month=FROM_MONTH)\n",
    "    print(f'IPC cargado: {len(df_ipc)} meses')\n",
    "    print('Brecha acumulada (canasta vs IPC general):')\n",
    "    last = df_comp.dropna(subset=['brecha_indice']).iloc[-1]\n",
    "    print(f'  {last[\"mes\"]}: canasta={last[\"indice\"]:.1f} vs IPC={last[\"indice_ipc\"]:.1f} → brecha={last[\"brecha_indice\"]:.1f} puntos')\n",
    "else:\n",
    "    df_ipc = pd.DataFrame()\n",
    "    df_comp = idx\n",
    "    print('⚠ IPC.xlsx no encontrado — comparativa no disponible')\n",
    "    print(f'Colocar el archivo en: {IPC_PATH}')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Tabla LaTeX para publicaciones académicas\n",
    "from sepa.analysis.basket import basket_by_province\n",
    "\n",
    "if not df_prov.empty:\n",
    "    last_month = df_prov['mes'].max()\n",
    "    df_rank = basket_by_province(df_prov, last_month)\n",
    "    print(f'\\nRanking provincial — {last_month}:')\n",
    "    display(df_rank[['ranking','provincia','canasta_provincia','vs_promedio_pct']].head(10))\n",
    "    \n",
    "    # LaTeX\n",
    "    latex = df_rank[['ranking','provincia','canasta_provincia','vs_promedio_pct']].to_latex(\n",
    "        index=False, float_format='%.0f',\n",
    "        caption=f'Canasta ICM-UADE por provincia — {last_month}',\n",
    "        label='tab:canasta_provincias'\n",
    "    )\n",
    "    print('\\nTabla LaTeX generada (copiar para publicaciones):')\n",
    "    print(latex[:800] + '...')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Gráficos\n",
    "from sepa.viz.charts import plot_index_series, plot_monthly_variations\n",
    "from IPython.display import Image, display as ipy_display\n",
    "\n",
    "PRODUCTS_DIR.mkdir(parents=True, exist_ok=True)\n",
    "\n",
    "if not df_comp.empty and 'indice' in df_comp.columns:\n",
    "    p1 = plot_index_series(df_comp, PRODUCTS_DIR / 'indices_consolidado.png',\n",
    "                           title='ICM-UADE vs. IPC INDEC (Base 100 = mayo 2023)')\n",
    "    p2 = plot_monthly_variations(df_comp, PRODUCTS_DIR / 'variaciones_consolidado.png')\n",
    "    print('Gráficos guardados:')\n",
    "    print(f'  {p1}')\n",
    "    print(f'  {p2}')\n",
    "    ipy_display(Image(str(p1)))"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Exportar consolidado\n",
    "from sepa.viz.exports import save_consolidated_excel\n",
    "\n",
    "out = OUTPUT_DIR / 'canasta_SEPA_consolidado.xlsx'\n",
    "save_consolidated_excel(df_nat_valid, df_prov, df_reg, df_ipc, df_comp, out)\n",
    "print(f'Consolidado guardado: {out}')"
   ]
  }
 ],
