{
 "cells": [
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# 04 — Evolución semestral de la canasta\n",
    "\n",
    "Procesa un semestre del SEPA y genera la serie temporal mensual de la canasta ICM-UADE\n",
    "por sucursal, provincia, región y nación ponderada por población.\n",
    "\n",
    "**Input:** ZIP semestral (e.g. `data/input/semestrales/2026A.zip`) + maestros  \n",
    "**Output:** `data/output/canasta_2026A_serie.xlsx` + Parquet en cache"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import sys, gc\n",
    "from pathlib import Path\n",
    "\n",
    "IS_COLAB = 'google.colab' in str(get_ipython()) if get_ipython() else False\n",
    "PROJECT_ROOT = Path('/content/analisis_precios_minoristas_UADE') if IS_COLAB else Path('..').resolve()\n",
    "if str(PROJECT_ROOT / 'src') not in sys.path:\n",
    "    sys.path.insert(0, str(PROJECT_ROOT / 'src'))\n",
    "\n",
    "# ── CONFIGURACIÓN — cambiar SEMESTRE para procesar otro período ─────────────\n",
    "SEMESTRE            = '2026A'\n",
    "SOURCE              = PROJECT_ROOT / 'data' / 'input' / 'semestrales' / f'{SEMESTRE}.zip'\n",
    "MAESTRO_PRODUCTOS   = PROJECT_ROOT / 'data' / 'masters' / 'Maestro de Productos Interno.xlsx'\n",
    "MAESTRO_SUCURSALES  = PROJECT_ROOT / 'data' / 'masters' / 'maestro_sucursales_completo.xlsx'\n",
    "\n",
    "print(f'Semestre: {SEMESTRE}')\n",
    "print(f'Fuente: {SOURCE} — existe: {SOURCE.exists()}')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import pandas as pd\n",
    "\n",
    "from sepa.pipeline.loader import iter_semester_csvgz, load_master_branches\n",
    "from sepa.pipeline.cleaner import clean_prices\n",
    "from sepa.pipeline.enricher import enrich_with_branches, filter_excluded_chains\n",
    "from sepa.pipeline.aggregator import (\n",
    "    compute_monthly_avg, build_branch_basket,\n",
    "    aggregate_by_province, aggregate_national_weighted\n",
    ")\n",
    "from sepa.config.canasta import CANASTA_EANS\n",
    "\n",
    "# Cargar y limpiar datos\n",
    "frames = []\n",
    "for chunk in iter_semester_csvgz(SOURCE, ean_filter=CANASTA_EANS):\n",
    "    chunk = filter_excluded_chains(chunk)\n",
    "    chunk = clean_prices(chunk, auto_scale=True)\n",
    "    frames.append(chunk)\n",
    "    gc.collect()\n",
    "\n",
    "df_long = pd.concat(frames, ignore_index=True)\n",
    "del frames; gc.collect()\n",
    "meses = sorted(df_long['fecha'].dt.to_period('M').astype(str).unique())\n",
    "print(f'Observaciones: {len(df_long):,}')\n",
    "print(f'Meses cubiertos: {meses}')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Verificar cobertura temporal por archivo\n",
    "df_long['mes'] = df_long['fecha'].dt.to_period('M').astype(str)\n",
    "df_long['n_dias'] = df_long['fecha'].dt.day\n",
    "cobertura = df_long.groupby('mes').agg(\n",
    "    dias_cubiertos=('fecha', lambda x: x.dt.day.nunique()),\n",
    "    n_registros=('precio', 'count')\n",
    ").reset_index()\n",
    "print('Cobertura temporal:')\n",
    "display(cobertura)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Enriquecer con maestro de sucursales\n",
    "if MAESTRO_SUCURSALES.exists():\n",
    "    mb = load_master_branches(MAESTRO_SUCURSALES)\n",
    "    df_enriched = enrich_with_branches(df_long, mb)\n",
    "    print(f'Provincias: {df_enriched[\"provincia\"].nunique() if \"provincia\" in df_enriched.columns else 0}')\n",
    "    print(f'Regiones: {df_enriched[\"region\"].nunique() if \"region\" in df_enriched.columns else 0}')\n",
    "else:\n",
    "    df_enriched = df_long\n",
    "    print('⚠ Sin maestro de sucursales')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Calcular canasta mensual por sucursal\n",
    "df_monthly = compute_monthly_avg(df_enriched)\n",
    "df_branch  = build_branch_basket(df_monthly)\n",
    "\n",
    "print(f'Sucursales con canasta: {len(df_branch):,}')\n",
    "print(f'Por mes:')\n",
    "display(df_branch.groupby('mes')['canasta_total'].agg(['count','mean','median']).round(0))"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Agregar por provincia y región\n",
    "df_prov = aggregate_by_province(df_branch, df_enriched)\n",
    "df_reg  = df_prov.merge(df_enriched[['provincia','region']].drop_duplicates(), on='provincia', how='left')\n",
    "df_reg  = df_reg.groupby(['region','mes'])['canasta_provincia'].mean().reset_index()\n",
    "df_nat  = aggregate_national_weighted(df_prov)\n",
    "\n",
    "print('\\nSerie nacional ponderada:')\n",
    "display(df_nat)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Exportar\n",
    "from sepa.viz.exports import save_parquet, save_semester_excel\n",
    "from sepa.config.settings import POPULATION_WEIGHTS\n",
    "\n",
    "# Cache parquet\n",
    "cache_path = PROJECT_ROOT / 'data' / 'cache' / f'canasta_branch_{SEMESTRE}.parquet'\n",
    "save_parquet(df_branch, cache_path)\n",
    "\n",
    "# Excel\n",
    "df_pesos = pd.DataFrame([{'provincia': k, 'poblacion': v, 'peso': v/sum(POPULATION_WEIGHTS.values())}\n",
    "                          for k,v in POPULATION_WEIGHTS.items()])\n",
    "save_semester_excel(\n",
    "    semester=SEMESTRE,\n",
    "    df_cobertura=cobertura,\n",
    "    df_diaria=None,\n",
    "    df_provincia=df_prov,\n",
    "    df_region=df_reg,\n",
    "    df_nacional=df_nat,\n",
    "    df_pesos=df_pesos,\n",
    "    output_dir=PROJECT_ROOT / 'data' / 'output',\n",
    ")\n",
    "print(f'Excel semestral guardado en data/output/canasta_{SEMESTRE}_serie.xlsx')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Diagnóstico: precios mensuales de productos de referencia\n",
    "from sepa.config.canasta import REFERENCE_EANS_FOR_SCALE\n",
    "\n",
    "ref_data = df_enriched[df_enriched['ean_norm'].isin(REFERENCE_EANS_FOR_SCALE)]\n",
    "if not ref_data.empty:\n",
    "    ref_pivot = ref_data.groupby(['ean_norm','mes'])['precio'].median().unstack('mes').round(2)\n",
    "    print('Precios medianos de productos de referencia por mes:')\n",
    "    display(ref_pivot)"
   ]
  }
 ],
