 "cells": [
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# 03 — Mapa interactivo de sucursales (ICM-UADE)\n",
    "\n",
    "Genera el mapa Folium con una marca por sucursal coloreada según el precio de la canasta.\n",
    "\n",
    "**Input:** CSVs mensuales comprimidos (.csv.gz) ya extraídos + maestros  \n",
    "**Output:** `products/mapa_canasta_YYYY-MM.html`"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import sys\n",
    "from pathlib import Path\n",
    "\n",
    "IS_COLAB = 'google.colab' in str(get_ipython()) if get_ipython() else False\n",
    "PROJECT_ROOT = Path('/content/analisis_precios_minoristas_UADE') if IS_COLAB else Path('..').resolve()\n",
    "if str(PROJECT_ROOT / 'src') not in sys.path:\n",
    "    sys.path.insert(0, str(PROJECT_ROOT / 'src'))\n",
    "\n",
    "# ── CONFIGURACIÓN ──────────────────────────────────────────────────────────\n",
    "# Carpeta con los CSV.GZ del mes o ruta al ZIP semestral\n",
    "SOURCE = PROJECT_ROOT / 'data' / 'input' / 'semestrales' / '2026A.zip'\n",
    "MES_OBJETIVO = '2026-04'  # None = último mes disponible\n",
    "\n",
    "MAESTRO_SUCURSALES = PROJECT_ROOT / 'data' / 'masters' / 'maestro_sucursales_completo.xlsx'\n",
    "MAESTRO_PRODUCTOS  = PROJECT_ROOT / 'data' / 'masters' / 'Maestro de Productos Interno.xlsx'\n",
    "\n",
    "print(f'Fuente: {SOURCE} — existe: {SOURCE.exists()}')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import gc\n",
    "import pandas as pd\n",
    "\n",
    "from sepa.pipeline.loader import iter_semester_csvgz, load_master_products, load_master_branches\n",
    "from sepa.pipeline.cleaner import clean_prices\n",
    "from sepa.pipeline.enricher import enrich_with_branches, filter_excluded_chains\n",
    "from sepa.pipeline.aggregator import compute_monthly_avg, build_branch_basket\n",
    "from sepa.config.canasta import CANASTA_EANS\n",
    "\n",
    "# Cargar datos\n",
    "frames = []\n",
    "for chunk in iter_semester_csvgz(SOURCE, ean_filter=CANASTA_EANS):\n",
    "    chunk = filter_excluded_chains(chunk)\n",
    "    chunk = clean_prices(chunk, auto_scale=True)\n",
    "    frames.append(chunk)\n",
    "    gc.collect()\n",
    "\n",
    "df_long = pd.concat(frames, ignore_index=True)\n",
    "del frames; gc.collect()\n",
    "print(f'Observaciones totales: {len(df_long):,}')\n",
    "print(f'Meses disponibles: {sorted(df_long[\"fecha\"].dt.to_period(\"M\").astype(str).unique())}')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Enriquecer con maestro de sucursales\n",
    "if MAESTRO_SUCURSALES.exists():\n",
    "    mb = load_master_branches(MAESTRO_SUCURSALES)\n",
    "    df_enriched = enrich_with_branches(df_long, mb)\n",
    "else:\n",
    "    df_enriched = df_long\n",
    "    print('⚠ Sin maestro de sucursales')\n",
    "\n",
    "print(f'Columnas disponibles: {list(df_enriched.columns)[:15]}')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Calcular canasta mensual por sucursal\n",
    "df_monthly = compute_monthly_avg(df_enriched)\n",
    "df_branch  = build_branch_basket(df_monthly)\n",
    "\n",
    "mes = MES_OBJETIVO or df_branch['mes'].max()\n",
    "print(f'Mes seleccionado: {mes}')\n",
    "print(f'Sucursales con canasta completa: {len(df_branch[df_branch[\"mes\"]==mes]):,}')\n",
    "print(df_branch[df_branch['mes']==mes]['canasta_total'].describe())"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Guardar en cache para reutilizar\n",
    "from sepa.viz.exports import save_parquet\n",
    "cache_path = PROJECT_ROOT / 'data' / 'cache' / f'canasta_branch_{mes.replace(\"-\",\"\")}.parquet'\n",
    "save_parquet(df_branch, cache_path)\n",
    "print(f'Cache guardado: {cache_path}')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Generar mapa interactivo\n",
    "from sepa.viz.maps import make_branch_map\n",
    "\n",
    "branch_cols = [c for c in ['id_comercio', 'id_bandera', 'id_sucursal'] if c in df_branch.columns]\n",
    "suc_info_cols = branch_cols + [c for c in ['lat', 'lng', 'cadena', 'provincia', 'region',\n",
    "                                             'sucursalnombre', 'localidad_nombre'] if c in df_enriched.columns]\n",
    "df_enriched_suc = df_enriched[suc_info_cols].drop_duplicates(subset=branch_cols)\n",
    "\n",
    "out_html = PROJECT_ROOT / 'products' / f'mapa_canasta_{mes.replace(\"-\",\"\")}.html'\n",
    "make_branch_map(df_branch, df_enriched_suc, out_html, mes=mes)\n",
    "print(f'Mapa guardado: {out_html}')\n",
    "print(f'Abrir en el navegador: {out_html}')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Rankings de cadenas\n",
    "from sepa.analysis.chains import national_ranking, amba_ranking\n",
    "from sepa.viz.charts import plot_chain_ranking\n",
    "\n",
    "rank_nac = national_ranking(df_branch, df_enriched_suc, mes=mes)\n",
    "rank_amba = amba_ranking(df_branch, df_enriched_suc, mes=mes)\n",
    "\n",
    "print('\\n── Ranking Nacional ──')\n",
    "display(rank_nac[['ranking', 'cadena', 'canasta_promedio', 'n_sucursales', 'vs_promedio_pct']])\n",
    "\n",
    "plot_chain_ranking(rank_nac,\n",
    "                   PROJECT_ROOT / 'products' / f'ranking_nacional_{mes.replace(\"-\",\"\")}.png',\n",
    "                   title=f'Ranking Nacional — {mes}')\n",
    "\n",
    "if not rank_amba.empty:\n",
    "    print('\\n── Ranking AMBA ──')\n",
    "    display(rank_amba[['ranking', 'cadena', 'canasta_promedio', 'n_sucursales', 'vs_promedio_pct']])\n",
    "    plot_chain_ranking(rank_amba,\n",
    "                       PROJECT_ROOT / 'products' / f'ranking_amba_{mes.replace(\"-\",\"\")}.png',\n",
    "                       title=f'Ranking AMBA — {mes}')"
   ]
  }
 ],
